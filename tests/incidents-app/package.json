{
  "name": "@capire/incidents",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/attachments": "file:../../.",
    "@cap-js/audit-logging": "^1.2.0",
    "@cap-js/hana": ">=2.6.0",
    "@cap-js/postgres": "^2.2.0",
    "@sap/cds": ">=9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "*"
  },
  "cds": {
    "fiori": {
      "bypass_draft": true
    },
    "log": {
      "levels": {
        "cds": "info"
      }
    },
    "requires": {
      "queue": {
        "parallel": true,
        "chunkSize": 50,
        "maxAttempts": 2
      },
      "auth": {
        "[development]": {
          "users": {
            "alice": {
              "roles": [
                "support",
                "admin"
              ]
            },
            "bob": {
              "roles": [
                "support"
              ]
            }
          }
        },
        "[hybrid]": {
          "kind": "mocked",
          "users": {
            "alice": {
              "roles": [
                "support",
                "admin"
              ]
            },
            "bob": {
              "roles": [
                "support"
              ]
            }
          }
        }
      }
    }
  },
  "private": true
}
