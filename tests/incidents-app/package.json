{
  "name": "@capire/incidents",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/attachments": "file:../../.",
    "@cap-js/hana": "2.6.0",
    "@cap-js/postgres": "^1"
  },
  "cds": {
    "log": {
      "levels": {
        "cds": "info"
      }
    },
    "requires": {
      "attachments": {
        "scanExpiryMs": 30000
      },
      "auth": {
        "[development]": {
          "users": {
            "alice": {
              "roles": [
                "support",
                "admin"
              ]
            },
            "bob": {
              "roles": [
                "support"
              ]
            }
          }
        },
        "[hybrid]": {
          "kind": "mocked",
          "users": {
            "alice": {
              "roles": [
                "support",
                "admin"
              ]
            },
            "bob": {
              "roles": [
                "support"
              ]
            }
          }
        }
      },
      "[postgres]": {
        "db": {
          "kind": "postgres",
          "credentials": {
            "url": "postgresql://postgres:password@localhost:5432/postgres",
            "host": "localhost",
            "port": 5432,
            "password": "password"
          }
        }
      }
    }
  },
  "private": true
}
